# API host (with or without trailing /api — the app normalizes)
VITE_API_BASE_URL=http://localhost:5000

# Optional explicit Socket.IO origin (no /api). If unset, derived from VITE_API_BASE_URL.
# VITE_SOCKET_URL=http://localhost:5000

# Legacy (still supported if VITE_API_BASE_URL is not set)
# VITE_API_URL=http://localhost:5000/api
