PORT=5000
NODE_ENV=development

JWT_SECRET=your_secret_min_32_chars

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# Legacy alias (optional): same as service role for server
# SUPABASE_KEY=

FRONTEND_URL=http://localhost:5173

# Shared secret for POST /api/telemetry (ESP32 / gateways). Required in production.
TELEMETRY_INGEST_KEY=supersecret123

# Simulated fleet jitter interval (ms)
TELEMETRY_EMIT_MS=15000
